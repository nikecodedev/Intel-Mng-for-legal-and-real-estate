# =============================================================================
# GEMS — Intel Management Platform
# Environment Variables Reference
#
# Copy this file to apps/api/.env and fill in real values.
# NEVER commit .env files with real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL) — REQUIRED
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://platform_user:change_me@localhost:5432/platform_db

# Pool tuning (optional — defaults shown)
DB_POOL_MAX=20
DB_POOL_MIN=5
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Redis — REQUIRED for rate limiting, sessions, token blacklist
# -----------------------------------------------------------------------------
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_DB=0
# Full URL (overrides host/port/password if set)
# REDIS_URL=redis://:change_me@localhost:6379/0

# -----------------------------------------------------------------------------
# JWT Authentication — REQUIRED
# JWT_SECRET must be at least 64 characters in production
# -----------------------------------------------------------------------------
JWT_SECRET=change_me_in_production_must_be_at_least_64_characters_long_xxxxxxxx
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000
NODE_ENV=production
API_VERSION=v1
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# CORS — REQUIRED in production (must not be "*")
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://164.92.71.218

# -----------------------------------------------------------------------------
# Google Gemini AI — REQUIRED for OCR, document extraction, petition generation
# Get key at: https://aistudio.google.com/
# -----------------------------------------------------------------------------
GEMINI_API_KEY=

# -----------------------------------------------------------------------------
# Antifraude API — OPTIONAL (falls back to heuristic scoring if unset)
# -----------------------------------------------------------------------------
ANTIFRAUDE_API_URL=
ANTIFRAUDE_API_KEY=

# -----------------------------------------------------------------------------
# Error Tracking — OPTIONAL
# Sentry: get DSN at sentry.io
# Webhook: POST payload with error details on 5xx errors
# -----------------------------------------------------------------------------
SENTRY_DSN=
ERROR_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# Email / Notifications — OPTIONAL
# Webhook called with investor match notifications and KYC expiry alerts
# -----------------------------------------------------------------------------
EMAIL_WEBHOOK_URL=

# -----------------------------------------------------------------------------
# SMS (MFA) — OPTIONAL
# SMS_PROVIDER: stub (default, logs only) | twilio | aws_sns
# -----------------------------------------------------------------------------
SMS_PROVIDER=stub

# Twilio (required if SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AWS SNS (required if SMS_PROVIDER=aws_sns)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SNS_SENDER_ID=GEMS

# -----------------------------------------------------------------------------
# Rate Limiting — OPTIONAL (defaults shown)
# -----------------------------------------------------------------------------
RATE_LIMIT_TENANT_MAX=1000
RATE_LIMIT_TENANT_WINDOW_MS=60000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Multi-tenant
# -----------------------------------------------------------------------------
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# -----------------------------------------------------------------------------
# Investor Portal (apps/web) — REQUIRED for web service
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://164.92.71.218/api/v1
